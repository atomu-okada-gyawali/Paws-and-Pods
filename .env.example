# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# JWT_ACCESS_SECRET: The secret key used to sign access tokens for session authentication.
JWT_ACCESS_SECRET="GENERATE_A_HIGH_ENTROPY_HMAC_SECRET"

# DB_ENCRYPTION_KEY: Hex-encoded 32-byte key used for field-level database encryption (AES-256-GCM).
DB_ENCRYPTION_KEY="GENERATE_64_CHARACTER_HEX_STRING"

# MONGODB_URI: MongoDB connection string for Mongoose.
MONGODB_URI="mongodb://localhost:27017/paws-and-pods"

# PORT: Server port (default 3000).
PORT=3000
